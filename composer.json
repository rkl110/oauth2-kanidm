{
    "name": "rkl110/oauth2-kanidm",
    "description": "Kanidm OAuth 2.0 Client Provider for The PHP League OAuth2-Client",
    "require": {
        "league/oauth2-client": "^2.0",
        "php": "^7.4||^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "squizlabs/php_codesniffer": "^3.6",
        "mockery/mockery": "^1.4"
    },
    "autoload-dev": {
        "psr-4": {
            "rkl110\\OAuth2\\Client\\Test\\": "test/src/"
        }
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Robert",
            "email": "",
            "homepage": ""
        }
    ],
    "autoload": {
        "psr-4": {
            "rkl110\\OAuth2\\Client\\": "src/"
        }
    },
    "scripts": {
        "check": "phpcs src tests --standard=PSR12 -sp",
        "cs-fix": "phpcbf src tests --standard=PSR12 -p"
    }
}
